generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Merchant {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores          Store[]
  warehouses      Warehouse[]
  customers       Customer[]
  promotionRules  PromotionRule[]
  suppliers        Supplier[]
  purchaseOrders   PurchaseOrder[]
  receivingNotes   ReceivingNote[]
}

model Customer {
  id          String   @id @default(uuid())
  merchant    Merchant @relation(fields: [merchantId], references: [id])
  merchantId  String
  code        String?
  name        String
  phone       String?
  email       String?
  memberLevel String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posOrders   PosOrder[]

  @@index([merchantId])
  @@index([merchantId, phone])
  @@index([merchantId, email])
}

/// 非同步大量匯入（單 process 內 setImmediate；多 instance 時每 pod 各自佇列）
model BulkImportJob {
  id         String   @id @default(uuid())
  kind       String
  status     String
  resultJson String?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// 促銷規則（Admin 設定；POS 依 merchant + 時間窗 + draft=false 套用）
model PromotionRule {
  id                 String   @id @default(uuid())
  merchant           Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId         String
  name               String
  priority           Int      @default(100)
  draft              Boolean  @default(true)
  startsAt           DateTime?
  endsAt             DateTime?
  exclusive          Boolean  @default(false)
  firstPurchaseOnly  Boolean  @default(false)
  memberLevels       Json     @default("[]")
  conditions         Json     @default("[]")
  actions            Json     @default("[]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([merchantId])
  @@index([merchantId, priority])
}

model Store {
  id         String   @id @default(uuid())
  code       String   @unique
  name       String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  merchantId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  warehouses Warehouse[]
  posOrders  PosOrder[]
}

model Warehouse {
  id         String   @id @default(uuid())
  code       String   @unique
  name       String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  merchantId String
  store      Store?   @relation(fields: [storeId], references: [id])
  storeId    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  inventoryEvents  InventoryEvent[]
  inventoryBalance InventoryBalance[]
  purchaseOrders   PurchaseOrder[]
}

model Category {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Brand {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String    @id @default(uuid())
  sku         String    @unique
  name        String
  description String?
  specSize    String?
  specColor   String?
  weightGrams Int?
  listPrice   Decimal   @default(0) @db.Decimal(12, 2)
  salePrice   Decimal   @default(0) @db.Decimal(12, 2)
  costPrice   Decimal?  @db.Decimal(12, 2)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  brandId     String?
  brand       Brand?    @relation(fields: [brandId], references: [id])
  tags        Json      @default("[]") // string[] e.g. ["熱銷","新品"]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  inventoryEvents  InventoryEvent[]
  inventoryBalance InventoryBalance[]
  posOrderItems         PosOrderItem[]
  purchaseOrderLines    PurchaseOrderLine[]

  @@index([brandId])
}

model InventoryEvent {
  id          String           @id @default(uuid())
  occurredAt  DateTime
  type        InventoryEventType
  product     Product          @relation(fields: [productId], references: [id])
  productId   String
  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])
  warehouseId String
  quantity    Int
  referenceId String?
  note        String?
  createdAt   DateTime         @default(now())

  @@index([productId, warehouseId, occurredAt])
}

model InventoryBalance {
  id          String    @id @default(uuid())
  product     Product   @relation(fields: [productId], references: [id])
  productId   String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  warehouseId String
  onHandQty   Int
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
}

model FinanceEvent {
  id          String          @id @default(uuid())
  occurredAt  DateTime
  type        FinanceEventType
  partyId     String
  currency    String
  amount      Decimal
  taxAmount   Decimal?
  referenceId String?
  note        String?
  createdAt   DateTime        @default(now())

  @@index([partyId, occurredAt])
}

model PosOrder {
  id                String        @id @default(uuid())
  orderNumber       String        @unique
  store             Store         @relation(fields: [storeId], references: [id])
  storeId           String
  customer          Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId        String?
  subtotalAmount    Decimal       @db.Decimal(12, 2)
  discountAmount    Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount       Decimal       @db.Decimal(12, 2)
  promotionApplied  Json?
  createdAt         DateTime      @default(now())

  items    PosOrderItem[]
  payments PosOrderPayment[]

  @@index([customerId])
}

model PosOrderPayment {
  id      String   @id @default(uuid())
  order   PosOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String
  method  String
  amount  Decimal
}

model PosOrderItem {
  id        String    @id @default(uuid())
  order     PosOrder  @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product   @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  unitPrice Decimal
}

enum InventoryEventType {
  PURCHASE_IN
  SALE_OUT
  RETURN_FROM_CUSTOMER
  RETURN_TO_SUPPLIER
  TRANSFER_OUT
  TRANSFER_IN
  STOCKTAKE_GAIN
  STOCKTAKE_LOSS
}

enum FinanceEventType {
  SALE_RECEIVABLE
  SALE_PAYMENT // 賒帳／部分付款時，每筆實收（referenceId = POS order id）
  SALE_REFUND
  PURCHASE_PAYABLE
  PURCHASE_REBATE
  PURCHASE_RETURN
  ADJUSTMENT
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum ReceivingNoteStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  RETURNED
}

model Supplier {
  id             String         @id @default(uuid())
  merchant       Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId     String
  code           String
  name           String
  contactPerson  String?
  phone          String?
  paymentTerms   String?
  status         SupplierStatus @default(ACTIVE)
  email          String?
  address        String?
  taxId          String?
  bankAccount    String?
  note           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  purchaseOrders PurchaseOrder[]

  @@unique([merchantId, code])
  @@index([merchantId])
}

model PurchaseOrder {
  id           String              @id @default(uuid())
  merchant     Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  supplierId   String
  warehouse    Warehouse           @relation(fields: [warehouseId], references: [id])
  warehouseId  String
  orderNumber  String
  expectedDate DateTime?
  orderDate    DateTime?
  status       PurchaseOrderStatus @default(DRAFT)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  lines        PurchaseOrderLine[]
  receivingNotes ReceivingNote[]

  @@unique([merchantId, orderNumber])
  @@index([merchantId])
  @@index([supplierId])
}

model PurchaseOrderLine {
  id           String        @id @default(uuid())
  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  poId         String
  product      Product       @relation(fields: [productId], references: [id])
  productId    String
  qtyOrdered   Int
  qtyReceived  Int           @default(0)
  unitCost     Decimal       @db.Decimal(12, 2)
  receivingNoteLines ReceivingNoteLine[]

  @@index([poId])
}

model ReceivingNote {
  id               String               @id @default(uuid())
  merchant         Merchant             @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId       String
  receiptNumber    String               @unique
  purchaseOrder    PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId  String
  inspectorName    String?
  remark           String?
  inspectionDate   DateTime?
  status           ReceivingNoteStatus  @default(PENDING)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  lines            ReceivingNoteLine[]

  @@index([merchantId])
  @@index([purchaseOrderId])
}

model ReceivingNoteLine {
  id                 String            @id @default(uuid())
  receivingNote      ReceivingNote     @relation(fields: [receivingNoteId], references: [id], onDelete: Cascade)
  receivingNoteId    String
  purchaseOrderLine  PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id])
  purchaseOrderLineId String
  orderedQty         Int
  receivedQty        Int               @default(0)
  qualifiedQty       Int               @default(0)
  returnedQty        Int               @default(0)
  returnReason       String?

  @@index([receivingNoteId])
}

