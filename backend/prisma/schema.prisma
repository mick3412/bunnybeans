generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Merchant {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores          Store[]
  warehouses      Warehouse[]
  customers       Customer[]
  promotionRules  PromotionRule[]
  suppliers        Supplier[]
  purchaseOrders   PurchaseOrder[]
  receivingNotes   ReceivingNote[]
  loyaltySettings  LoyaltySettings?
  loyaltyCoupons   LoyaltyCoupon[]
  pointLedgers     PointLedger[]
  segments        Segment[]
  tierRules       TierRule[]
  productTags     ProductTag[]
}

model Customer {
  id           String   @id @default(uuid())
  merchant     Merchant @relation(fields: [merchantId], references: [id])
  merchantId   String
  code         String?
  name         String
  phone        String?
  email        String?
  memberLevel  String?
  memberCode   String?
  joinDate     DateTime?
  status       String   @default("ACTIVE") // ACTIVE | BLOCKED
  blockReason  String?
  tags         Json     @default("[]") // string[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  posOrders    PosOrder[]
  pointLedgers     PointLedger[]
  contactLogs      CustomerContactLog[]
  couponIssues     LoyaltyCouponIssue[]

  @@index([merchantId])
  @@index([merchantId, phone])
  @@index([merchantId, email])
  @@index([merchantId, status])
}

model CustomerContactLog {
  id             String   @id @default(uuid())
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId     String
  type           String   // e.g. CALL, VISIT, NOTE
  note           String?
  nextFollowUpAt DateTime?
  createdBy     String?
  createdAt      DateTime @default(now())

  @@index([customerId])
}

/// 分群（階段 E）：JSON 條件可後續擴充 tag／memberLevel／消費區間等
model Segment {
  id         String   @id @default(uuid())
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId String
  name       String
  conditions Json?    // e.g. { tag?: string, memberLevel?: string }; empty = all
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([merchantId])
}

/// 分級規則（階段 E）：累積消費／筆數等達門檻則升級為 targetLevel
model TierRule {
  id           String   @id @default(uuid())
  merchant     Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId   String
  name         String
  ruleType     String   // SPEND_SUM | ORDER_COUNT（先實作 SPEND_SUM）
  threshold    Decimal  @db.Decimal(12, 2) // 累積金額或筆數門檻
  targetLevel  String   // 達標後設為此 memberLevel，如 VIP
  lookbackDays Int      @default(365)     // 統計區間（天）
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([merchantId])
}

/// 非同步大量匯入（單 process 內 setImmediate；多 instance 時每 pod 各自佇列）
model BulkImportJob {
  id         String   @id @default(uuid())
  kind       String
  status     String
  resultJson String?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// 階段 G：CRM 分群發券 job
model CrmMarketingJob {
  id          String   @id @default(uuid())
  merchantId  String
  kind        String
  segmentId   String
  couponId    String
  status      String
  resultJson  String?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([merchantId])
  @@index([status])
}

/// 階段 G：會員發券紀錄
model LoyaltyCouponIssue {
  id         String       @id @default(uuid())
  customer   Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  coupon     LoyaltyCoupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  couponId   String
  issuedAt   DateTime     @default(now())
  @@unique([customerId, couponId])
  @@index([couponId])
}

/// 階段 G：行銷發券規則常駐
model CrmCouponDispatchRule {
  id           String   @id @default(uuid())
  merchantId   String
  name         String
  segmentId    String
  couponId     String
  enabled      Boolean  @default(true)
  scheduleType String
  cronExpr     String?
  nextRunAt    DateTime?
  lastRunAt    DateTime?
  lastRunCode  String?
  lastRunNote  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([merchantId])
  @@index([merchantId, enabled])
  @@index([merchantId, lastRunAt])
}

/// 關帳期間（§7.1）
model FinancePeriodClose {
  id         String   @id @default(uuid())
  merchantId String?
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  closedAt   DateTime @default(now())
  closedBy   String?
  status     String   @default("CLOSED")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([merchantId, startDate, endDate])
}

/// 金流 Audit Log（§7.2）
model FinanceAuditLog {
  id        String   @id @default(uuid())
  eventId   String
  actor     String?
  source    String?
  amount    Decimal? @db.Decimal(12, 2)
  eventType String?
  createdAt DateTime @default(now())
  @@index([eventId])
  @@index([createdAt])
}

/// 財務快照（最小版）：手動補跑 daily/monthly 後保存結果，供列表查詢
model FinanceSnapshot {
  id         String   @id @default(uuid())
  asOfDate   DateTime @db.Date
  type       String   // daily | monthly
  path       String
  summaryJson Json
  createdAt  DateTime @default(now())

  @@unique([asOfDate, type])
  @@index([createdAt])
}

/// 促銷規則（Admin 設定；POS 依 merchant + 時間窗 + draft=false 套用）
model PromotionRule {
  id                 String   @id @default(uuid())
  merchant           Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId         String
  name               String
  priority           Int      @default(100)
  draft              Boolean  @default(true)
  startsAt           DateTime?
  endsAt             DateTime?
  exclusive          Boolean  @default(false)
  firstPurchaseOnly  Boolean  @default(false)
  memberLevels       Json     @default("[]")
  conditions         Json     @default("[]")
  actions            Json     @default("[]")
  usageCount         Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([merchantId])
  @@index([merchantId, priority])
}

model LoyaltySettings {
  id                   String   @id @default(uuid())
  merchant             Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId           String   @unique
  earnPerNT            Decimal  @default(100) @db.Decimal(12, 2)
  pointValueNT         Decimal  @default(1) @db.Decimal(12, 4)
  birthdayMultiplier   Decimal  @default(1) @db.Decimal(6, 2)
  rollingDays          Int      @default(365)
  notifyDaysBefore     Int      @default(30)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model PointLedger {
  id           String          @id @default(uuid())
  merchant     Merchant        @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId   String
  customer     Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId   String
  type         PointLedgerType
  amount       Int
  balanceAfter Int
  txnCode      String?
  referenceId  String?
  note         String?
  createdAt    DateTime        @default(now())

  @@index([merchantId, customerId, createdAt])
  @@index([merchantId, type])
}

model LoyaltyCoupon {
  id          String    @id @default(uuid())
  merchant    Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId  String
  code        String
  name        String
  discountType String
  value       Decimal   @db.Decimal(12, 2)
  validFrom   DateTime?
  validTo     DateTime?
  maxUses     Int?
  usedCount   Int       @default(0)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  couponIssues LoyaltyCouponIssue[]

  @@unique([merchantId, code])
  @@index([merchantId])
}

enum PointLedgerType {
  EARNED
  BURNED
  LOCKED
  EXPIRED
}

model Store {
  id         String   @id @default(uuid())
  code       String   @unique
  name       String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  merchantId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  warehouses Warehouse[]
  posOrders  PosOrder[]
}

model Warehouse {
  id         String   @id @default(uuid())
  code       String   @unique
  name       String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  merchantId String
  store      Store?   @relation(fields: [storeId], references: [id])
  storeId    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  inventoryEvents  InventoryEvent[]
  inventoryBalance InventoryBalance[]
  purchaseOrders   PurchaseOrder[]
}

model Category {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ProductTag {
  id         String   @id @default(uuid())
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId String
  name       String
  code       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([merchantId, code])
  @@index([merchantId])
}

model Brand {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String    @id @default(uuid())
  sku         String    @unique
  barcode     String?
  name        String
  description String?
  specSize    String?
  specColor   String?   // deprecated: use specStyle
  weightGrams Int?      // deprecated: use specWeight
  /// 容量（如「500ml」）
  specCapacity     String?
  /// 款式（取代 specColor 語意）
  specStyle        String?
  /// 重量含單位（如「200g」「1kg」）
  specWeight       String?
  /// 有效期限描述（如「常溫 1 年」）
  expiryDescription String?
  /// 生產日期（與 shelfLifeMonths 搭配計算到期日）
  productionDate    DateTime?
  /// 有效期限月數（與 productionDate 搭配）
  shelfLifeMonths   Int?
  /// 到期日期（與 productionDate+shelfLifeMonths 二擇一）
  expiryDate        DateTime?
  listPrice   Decimal   @default(0) @db.Decimal(12, 2)
  salePrice   Decimal   @default(0) @db.Decimal(12, 2)
  costPrice   Decimal?  @db.Decimal(12, 2)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  brandId     String?
  brand       Brand?    @relation(fields: [brandId], references: [id])
  tags        Json      @default("[]") // string[] e.g. ["熱銷","新品"]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  inventoryEvents  InventoryEvent[]
  inventoryBalance InventoryBalance[]
  posOrderItems         PosOrderItem[]
  purchaseOrderLines    PurchaseOrderLine[]

  @@index([barcode])
  @@index([brandId])
  @@index([categoryId])
}

model InventoryEvent {
  id          String           @id @default(uuid())
  occurredAt  DateTime
  type        InventoryEventType
  product     Product          @relation(fields: [productId], references: [id])
  productId   String
  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])
  warehouseId String
  quantity    Int
  /// 批號（由進貨驗收等流程帶入；選填）
  batchCode   String?
  /// 效期（由進貨驗收等流程帶入；選填）
  expiryDate  DateTime?
  /// 重量單位（例如 KG, G；選填）
  weightUnit  String?
  referenceId String?
  note        String?
  createdAt   DateTime         @default(now())

  @@index([productId, warehouseId, occurredAt])
}

model InventoryBalance {
  id          String    @id @default(uuid())
  product     Product   @relation(fields: [productId], references: [id])
  productId   String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  warehouseId String
  onHandQty   Int
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
}

model FinanceEvent {
  id          String          @id @default(uuid())
  occurredAt  DateTime
  type        FinanceEventType
  partyId     String
  currency    String
  amount      Decimal
  taxAmount   Decimal?
  referenceId String?
  note        String?
  createdAt   DateTime        @default(now())

  @@index([partyId, occurredAt])
}

model PosOrder {
  id                String        @id @default(uuid())
  orderNumber       String        @unique
  store             Store         @relation(fields: [storeId], references: [id])
  storeId           String
  customer          Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId        String?
  /// 換貨關聯：若此單為換貨後的新單，指向「原單」PosOrder.id
  exchangeFromOrderId String?
  subtotalAmount    Decimal       @db.Decimal(12, 2)
  discountAmount    Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount       Decimal       @db.Decimal(12, 2)
  promotionApplied  Json?
  createdAt         DateTime      @default(now())

  items    PosOrderItem[]
  payments PosOrderPayment[]

  @@index([customerId])
  @@index([customerId, createdAt])
  @@index([exchangeFromOrderId])
}

model PosOrderPayment {
  id      String   @id @default(uuid())
  order   PosOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String
  method  String
  amount  Decimal
}

model PosOrderItem {
  id        String    @id @default(uuid())
  order     PosOrder  @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product   @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  unitPrice Decimal

  @@index([orderId])
  @@index([productId])
}

enum InventoryEventType {
  PURCHASE_IN
  SALE_OUT
  RETURN_FROM_CUSTOMER
  RETURN_TO_SUPPLIER
  TRANSFER_OUT
  TRANSFER_IN
  STOCKTAKE_GAIN
  STOCKTAKE_LOSS
}

enum FinanceEventType {
  SALE_RECEIVABLE
  SALE_PAYMENT // 賒帳／部分付款時，每筆實收（referenceId = POS order id）
  SALE_REFUND
  PURCHASE_PAYABLE
  PURCHASE_REBATE
  PURCHASE_RETURN
  ADJUSTMENT
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum ReceivingNoteStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  RETURNED
}

model Supplier {
  id             String         @id @default(uuid())
  merchant       Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId     String
  code           String
  name           String
  contactPerson  String?
  phone          String?
  paymentTerms   String?
  status         SupplierStatus @default(ACTIVE)
  email          String?
  address        String?
  taxId          String?
  bankAccount    String?
  note           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  purchaseOrders PurchaseOrder[]

  @@unique([merchantId, code])
  @@index([merchantId])
}

model PurchaseOrder {
  id           String              @id @default(uuid())
  merchant     Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  supplierId   String
  warehouse    Warehouse           @relation(fields: [warehouseId], references: [id])
  warehouseId  String
  orderNumber  String
  expectedDate DateTime?
  orderDate    DateTime?
  status       PurchaseOrderStatus @default(DRAFT)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  lines        PurchaseOrderLine[]
  receivingNotes ReceivingNote[]

  @@unique([merchantId, orderNumber])
  @@index([merchantId])
  @@index([supplierId])
}

model PurchaseOrderLine {
  id           String        @id @default(uuid())
  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  poId         String
  product      Product       @relation(fields: [productId], references: [id])
  productId    String
  qtyOrdered   Int
  qtyReceived  Int           @default(0)
  unitCost     Decimal       @db.Decimal(12, 2)
  receivingNoteLines ReceivingNoteLine[]

  @@index([poId])
}

model ReceivingNote {
  id               String               @id @default(uuid())
  merchant         Merchant             @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId       String
  receiptNumber    String               @unique
  purchaseOrder    PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId  String
  inspectorName    String?
  remark           String?
  inspectionDate   DateTime?
  status           ReceivingNoteStatus  @default(PENDING)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  lines            ReceivingNoteLine[]

  @@index([merchantId])
  @@index([purchaseOrderId])
}

model ReceivingNoteLine {
  id                 String            @id @default(uuid())
  receivingNote      ReceivingNote     @relation(fields: [receivingNoteId], references: [id], onDelete: Cascade)
  receivingNoteId    String
  purchaseOrderLine  PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id])
  purchaseOrderLineId String
  orderedQty         Int
  receivedQty        Int               @default(0)
  qualifiedQty       Int               @default(0)
  returnedQty        Int               @default(0)
  returnReason       String?
  /// 進貨批號（選填，用於庫存批次／效期管理）
  batchCode          String?
  /// 進貨效期日（選填，用於庫存批次／效期管理）
  expiryDate         DateTime?
  /// 重量單位（例如 KG, G；選填，用於飼料等商品）
  weightUnit         String?

  @@index([receivingNoteId])
}

/// 運維：定時 job 最近一次執行紀錄（發券排程／關帳／快照）
model OpsJobRunLog {
  id        String   @id @default(uuid())
  jobType   String   // e.g. crm-run-scheduled, finance-period-close, finance-snapshot
  lastRunAt DateTime @default(now())
  success   Boolean
  message   String?  // error summary when success=false
  createdAt DateTime @default(now())
  @@index([jobType])
}

/// 報表穿透審計（ReportClickAudit）：記錄使用者點擊 referenceId 的解析結果與成功率
model ReportClickAudit {
  id           String   @id @default(uuid())
  merchantId   String?
  source       String   // e.g. finance-events, loyalty-ledger, pos-reports
  field        String   // e.g. referenceId
  referenceId  String
  /// 點擊結果分類（前端可回報；用於可觀測性與 UX 改善）
  resultCode   String?
  resolvedKind String   // posOrder | receivingNote | unknown（先以字串存，避免未來擴充需 migration）
  success      Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([merchantId])
  @@index([source])
  @@index([resultCode])
  @@index([resolvedKind])
  @@index([createdAt])
}

