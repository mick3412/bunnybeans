###############################################################################
# E2E 專用 DB（隔離 demo DB 最簡單方式）
#
# 目的：
# - `pnpm db:seed` 會先 wipeAll() 清空業務表再重建完整 demo 數據
# - 所以跑 E2E 前務必改用「獨立 DB」，避免清到你的 demo DB
#
# 用法：
# 1) 複製：cp .env.e2e.example .env.e2e
# 2) 修改 DATABASE_URL 指到另一個資料庫（例如 pos_erp_e2e）
# 3) 執行：./scripts/e2e-one-click-isolated.sh
###############################################################################

# 範例（請依你本機帳密調整）
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pos_erp_e2e?schema=public"

# 若要跑 full fixtures（換貨 settlement / dispatch-rules / 報表資料集）
# E2E_PROFILE=full

